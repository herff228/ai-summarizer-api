# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=summarizer_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/summarizer_db

# Hugging Face model (small summarization model)
HF_MODEL_NAME=facebook/bart-large-cnn
# Альтернативы: "t5-small", "google/pegasus-cnn_dailymail"
MAX_LENGTH=150
MIN_LENGTH=30